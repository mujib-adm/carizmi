{
  "name": "carizmi-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate:api": "rm -rf src/api/generated && orval",
    "postgenerate:api": "node clean-orval.mjs",
    "serve": "serve -s dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "antd": "^5.29.1",
    "axios": "^1.15.2",
    "http-status-codes": "^2.3.0",
    "jwt-decode": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^6.23.1",
    "recharts": "^3.6.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "orval": "^8.5.3",
    "prettier": "^3.8.1",
    "serve": "^14.2.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
