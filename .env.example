# ==============================================================================
# Carizmi Platform — Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and fill in the values for your local environment.
#
#   cp .env.example .env
#
# WARNING: Never commit the actual '.env' file to version control.
# ==============================================================================

# App Port
APP_PORT=8080

# Spring Profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# JVM Memory
JAVA_OPTS=-Xms256m -Xmx512m

# Default Admin User (auto-provisioned on first startup)
ADMIN_DEFAULT_FIRSTNAME=System
ADMIN_DEFAULT_LASTNAME=Administrator
ADMIN_DEFAULT_EMAIL=admin@mail.com
ADMIN_DEFAULT_USERNAME=admin

# JWT secret: minimum 64 bytes (512-bit) for HS512 signing.
# Generate with: openssl rand -base64 64
# WARNING: PRODUCTION values must be injected via env var or Secret Manager. NEVER commit real secrets.
JWT_SECRET=<generate-with-openssl-rand-base64-64>

# Database
DB_NAME=carizmi
DB_USER=carizmi
DB_PASS=carizmi_pwd
DB_ROOT_PASS=root_pwd_change_me
DB_URL=jdbc:mysql://db:3306/${DB_NAME}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&zeroDateTimeBehavior=CONVERT_TO_NULL&characterEncoding=UTF-8

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend
VITE_API_URL=http://localhost:8080/api
APP_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173

# Branding (injected into frontend config.js at container startup via envsubst)
APP_ORG_NAME=Your Organization Name
APP_HEADER_TITLE=YOUR ORG
APP_HEADER_SUBTITLE=COMMUNITY PORTAL
APP_LOGO_ALT=Organization Logo
APP_COPYRIGHT=© 2026 Your Organization Name.
